name: Pipeline

on: [push]

jobs:
  deploy:
    if: github.ref == 'refs/heads/main'
    name: Deploy
    runs-on: ubuntu-latest
    env:
      UNSCRAMBLED_API_KEY: ${{ secrets.UNSCRAMBLED_API_KEY }}
    steps:
      - uses: actions/checkout@v3
      - uses: actions/setup-node@v3
        with:
          node-version: 16
      - run: npm install
      - run: npm run deploy
